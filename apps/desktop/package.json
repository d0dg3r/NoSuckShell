{
  "name": "desktop",
  "version": "0.3.2",
  "description": "Cross-platform SSH manager desktop app",
  "scripts": {
    "postinstall": "patch-package",
    "dev": "vite",
    "build": "rm -rf dist && tsc && vite build",
    "build:e2e": "tsc && vite build --mode e2e",
    "preview": "vite preview",
    "preview:e2e": "vite preview --mode e2e --host 127.0.0.1 --port 4180",
    "tauri:dev": "tauri dev",
    "tauri:build": "tauri build",
    "test": "vitest run",
    "test:e2e": "playwright test",
    "screenshots": "npm run build:e2e && playwright test e2e/screenshots/generate.spec.ts"
  },
  "keywords": [],
  "author": "",
  "license": "MIT",
  "type": "module",
  "dependencies": {
    "@monaco-editor/react": "^4.7.0",
    "@novnc/novnc": "^1.6.0",
    "@tauri-apps/api": "^2.10.1",
    "@tauri-apps/plugin-dialog": "^2.6.0",
    "@xterm/addon-fit": "^0.11.0",
    "@xterm/xterm": "^6.0.0",
    "monaco-editor": "^0.55.1",
    "react": "^19.2.4",
    "react-dom": "^19.2.4"
  },
  "devDependencies": {
    "@playwright/test": "^1.51.0",
    "@tauri-apps/cli": "^2.10.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@types/node": "^25.5.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.1",
    "esbuild": "^0.27.4",
    "jsdom": "^29.0.1",
    "patch-package": "^8.0.1",
    "typescript": "^5.9.3",
    "vite": "^8.0.1",
    "vite-plugin-monaco-editor": "^1.1.0",
    "vitest": "^4.1.0"
  }
}
